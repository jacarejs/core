import { pulse, derive } from '@jacare/core'
import Tip from '../components/Tip.jcr'
import Demo from '../components/Demo.jcr'
import { appHref } from '../app-base.js'
import {
  reservedBlocksCode,
  reservedDirectivesCode,
  allBindsCode,
  bindsWithIfCode,
  contractBindCode,
  cliCreateRunBuildCode,
} from '../snippets/language.js'

const draft = pulse('')
const on = pulse(false)
const href = pulse('/about')
const busy = pulse(false)
const width = pulse(45)
const pct = derive(() => width() + '%')
const tab = pulse('a')

const show = pulse(true)
const email = pulse('')
const err = pulse('')

const blockRows = [
  { token: 'export <' + 'view>', role: 'Markup + bindings (required)' },
  { token: 'export <' + 'style>', role: 'Scoped CSS (optional, last)' },
  { token: 'export <' + 'contract>', role: 'props · pulses · slots · emits · links' },
]

const directiveRows = [
  { token: '#if / #elif / #else / #end', role: 'Conditional branches (@if alias)' },
  { token: '#case / #when / #else', role: 'Match one value (Object.is)' },
  { token: '#for list as item (key)', role: 'Keyed list (@each alias)' },
]

const prefixRows = [
  { token: 'on-* / @*', role: 'DOM events' },
  { token: 'bind-*', role: 'Attr / two-way model / model prop' },
  { token: ':*', role: 'One-way attr or component prop' },
  { token: 'class-* / class:*', role: 'Toggle class' },
  { token: 'style---* / style:*', role: 'CSS var --*' },
  { token: '${@bag/key}', role: 'Pulse Mesh address' },
]

const specialRows = [
  { token: '<slot> / slot="name"', role: 'Content projection' },
  { token: '<debug>', role: 'Dev JSON inspector (prod-stripped)' },
  { token: 'jacare-frame / jacare-go', role: 'Nav mount + client links' },
]

const cliRows = [
  { token: 'jacare new / create-jacare', role: 'Scaffold project' },
  { token: 'jacare dev', role: 'Dev server + HMR' },
  { token: 'jacare build', role: 'Production → dist/' },
  { token: 'jacare check [--bindings]', role: 'Contracts + Mesh links + IR' },
  { token: 'jacare compile', role: 'Single-file compile' },
]

const runtimeRows = [
  { area: 'State', mechanism: 'signal / pulse · computed / derive' },
  { area: 'Effects', mechanism: 'effect / watch · batch · untrack' },
  { area: 'Shared', mechanism: 'createBag / getBag · ripple · snap / hydrate' },
  { area: 'Text / attrs', mechanism: 'bindText · bindAttribute · bindClass · bindStyleVar' },
  { area: 'Model', mechanism: 'bindModel (bind-value / bind-checked)' },
  { area: 'Conditional', mechanism: 'branch / showIf (#if / #elif / #else / #case)' },
  { area: 'List', mechanism: 'reconcileKeyedList (#for … (key))' },
  { area: 'App', mechanism: 'createNav · createForm · createLifecycle' },
  { area: 'SSR', mechanism: 'renderToString · renderToStream · resumeBindings' },
  { area: 'DevTools', mechanism: 'devtoolsBind · registerScope · Pulse / Mesh / Scope' },
  { area: 'Compiler', mechanism: 'Binding IR · MountPlan · CPW · jacare check' },
]

export <view>
  <section class="page">
    <header class="page-hero">
      <p class="page-kicker">Language reference</p>
      <h1 class="page-title">Reserved words & bindings</h1>
      <p class="page-lead">
        Complete map of Jacaré — runtime mechanisms, module blocks, directives, attribute prefixes,
        every bind form, and CLI create / run / build. Written docs:
        <code>docs/language-reference.md</code>
        and
        <code>docs/api.md</code>
        §2b · §5 · §17 · §20
        <a class="text-link" jacare-go="/helpers" href=${appHref('/helpers')}>Import catalog</a>.
        Featured compiler lesson:
        <a class="text-link" jacare-go="/binding-ir" href=${appHref('/binding-ir')}>Binding IR</a>.
      </p>
    </header>

    <Tip :text=${'Jacaré files are plain JavaScript. Tokens below are reserved by the compiler or runtime in the positions shown — not all are JS keywords. Prefer bare ${count} over redundant ${() => count()} when there is no loop local to capture. Toggle DevTools from the top bar anytime.'} />

    <div class="lesson-grid">
      <Demo :title=${'Runtime map'} :lead=${'What powers templates under the hood — the same surface as the private architecture notes.'} :code=${reservedBlocksCode}>
        <div class="nav-live">
          #for runtimeRows as row (row.area)
            <div class="nav-live-row">
              <code>${row.area}</code>
              <span>${row.mechanism}</span>
            </div>
          #end
        </div>
        <div class="row" style="margin-top:0.75rem;flex-wrap:wrap;gap:0.5rem">
          <a class="btn btn-outline" jacare-go="/reactivity" href=${appHref('/reactivity')}>Reactivity</a>
          <a class="btn btn-outline" jacare-go="/bag" href=${appHref('/bag')}>Pulse bags</a>
          <a class="btn btn-outline" jacare-go="/binding-ir" href=${appHref('/binding-ir')}>Binding IR</a>
          <a class="btn btn-outline" jacare-go="/nav" href=${appHref('/nav')}>Navigation</a>
          <a class="btn btn-outline" jacare-go="/forms" href=${appHref('/forms')}>Forms</a>
          <a class="btn btn-outline" jacare-go="/ssr" href=${appHref('/ssr')}>SSR</a>
          <a class="btn btn-outline" jacare-go="/helpers" href=${appHref('/helpers')}>Imports</a>
        </div>
      </Demo>

      <Demo :title=${'Module blocks'} :lead=${'view is required. style is scoped. contract declares the public surface for jacare check.'} :code=${reservedBlocksCode}>
        <div class="nav-live">
          #for blockRows as row (row.token)
            <div class="nav-live-row">
              <code>${row.token}</code>
              <span>${row.role}</span>
            </div>
          #end
        </div>
      </Demo>

      <Demo :title=${'Directives'} :lead=${'Must start on their own line. Work inside view and inside style.'} :code=${reservedDirectivesCode}>
        <div class="nav-live">
          #for directiveRows as row (row.token)
            <div class="nav-live-row">
              <code>${row.token}</code>
              <span>${row.role}</span>
            </div>
          #end
        </div>
      </Demo>

      <Demo :title=${'Attribute prefixes'} :lead=${'Parsed before HTML attributes. On PascalCase tags, : is a prop and bind- is a model prop.'} :code=${allBindsCode}>
        <div class="nav-live">
          #for prefixRows as row (row.token)
            <div class="nav-live-row">
              <code>${row.token}</code>
              <span>${row.role}</span>
            </div>
          #end
        </div>
      </Demo>

      <Demo :title=${'All binds live'} :lead=${'bind-value, bind-checked, bind-href, :disabled, class-active, style---pct on one panel.'} :code=${allBindsCode}>
        <div class="stack">
          <input class="input" bind-value=${draft} placeholder="bind-value" />
          <label class="row"><input type="checkbox" bind-checked=${on} /> bind-checked</label>
          <a class="btn btn-outline" bind-href=${href}>bind-href → ${href}</a>
          <button type="button" class="btn" :disabled=${busy} on-click=${() => busy.update((v) => !v)}>
            :disabled (${busy})
          </button>
          <div class="row">
            <button type="button" class="btn btn-outline" class-active=${tab() === 'a'} on-click=${() => tab.set('a')}>A</button>
            <button type="button" class="btn btn-outline" class-active=${tab() === 'b'} on-click=${() => tab.set('b')}>B</button>
          </div>
          <div class="bar" style---pct=${pct}></div>
          <input class="input" type="range" min="0" max="100" bind-value=${width} />
          <p class="muted">draft=${draft} · on=${on} · pct=${pct}</p>
        </div>
      </Demo>

      <Demo :title=${'Binds + #if'} :lead=${'Two-way inputs nest cleanly inside conditionals — inactive arms leave the DOM.'} :code=${bindsWithIfCode}>
        <div class="stack">
          <label class="row"><input type="checkbox" bind-checked=${show} /> Show form</label>
          #if show()
            <input class="input" bind-value=${email} placeholder="Email" />
            #if err()
              <p class="muted">${err}</p>
            #else
              <p class="muted">Looks good — ${email}</p>
            #end
          #else
            <p class="muted">Form hidden</p>
          #end
        </div>
      </Demo>

      <Demo :title=${'Contract + model bind'} :lead=${'Parents must use bind-name for model: true props — :name fails jacare check.'} :code=${contractBindCode}>
        <pre class="log">${contractBindCode}</pre>
      </Demo>

      <Demo :title=${'Special tags'} :lead=${'slot, debug, and nav attributes are Jacaré-reserved in templates.'} :code=${reservedBlocksCode}>
        <div class="nav-live">
          #for specialRows as row (row.token)
            <div class="nav-live-row">
              <code>${row.token}</code>
              <span>${row.role}</span>
            </div>
          #end
        </div>
      </Demo>

      <Demo :title=${'Create · run · build'} :lead=${'Scaffold with create-jacare or jacare new, then dev / build / check.'} :code=${cliCreateRunBuildCode}>
        <div class="nav-live nav-live-cli">
          #for cliRows as row (row.token)
            <div class="nav-live-row">
              <code>${row.token}</code>
              <span>${row.role}</span>
            </div>
          #end
        </div>
        <pre class="log">${cliCreateRunBuildCode}</pre>
      </Demo>
    </div>
  </section>
</view>

export <style>
.bar {
  width: var(--pct);
  height: 8px;
  background: #189030;
  border-radius: 4px;
  transition: width 0.12s ease;
}
.btn-outline.active {
  outline: 2px solid #189030;
}
</style>
