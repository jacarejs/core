}

@media (max-width: 720px) {
  .mesh-ports,
  .mesh-leaves {
    grid-template-columns: 1fr;
  }

  .mesh-links {
    display: none;
  }

  .mesh-leaf {
    justify-items: start;
    text-align: left;
    padding: 0.75rem 0.85rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .mesh-hub,
  .mesh-port,
  .mesh-leaf,
  .mesh-link {
    transition: none;
  }
}
</style>
