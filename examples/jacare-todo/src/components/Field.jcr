import { view } from '@jacare/core'

export default view`
<label class="field">
  <span class="field-label">${label}</span>
  <input
    class="input field-input"
    class-invalid=${() => !!field.error()}
    type=${type}
    placeholder=${placeholder}
    bind-value=${field}
    on-blur=${() => field.blur()}
  />
  #if field.error()
    <span class="field-error">${field.error()}</span>
  #end
</label>
`
