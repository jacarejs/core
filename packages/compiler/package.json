{
  "name": "@jacare/compiler",
  "version": "0.1.9",
  "description": "Jacaré compiler — .jcr templates to optimized DOM code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/compiler"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "jacare-compile": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "yarn build"
  },
  "sideEffects": false,
  "dependencies": {
    "source-map-js": "^1.2.1"
  }
}
