{
  "name": "@jacare/devtools",
  "version": "0.1.9",
  "description": "Jacaré DevTools — Pulse Graph inspector",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/devtools"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
