  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@jacare/core": "0.1.9"
  },
  "sideEffects": false
}
