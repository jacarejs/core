{
  "name": "create-jacare",
  "version": "0.1.10",
  "description": "Scaffold Jacaré apps with Vite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/create-jacare"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "create-jacare": "./index.js"
  },
  "files": [
    "index.js",
    "scaffold.js",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./index.js",
    "./scaffold.js": "./scaffold.js"
  },
  "scripts": {
    "prepublishOnly": "rm -rf templates && cp -R ../../templates templates"
  }
}
