{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Jacaré",
  "scopeName": "source.jacare",
  "patterns": [
    {
      "include": "#script"
    }
  ],
  "repository": {
    "script": {
      "patterns": [
        {
          "include": "#style-blocks"
        },
        {
          "include": "#contract-block"
        },
        {
          "include": "#view-block"
        },
        {
          "include": "#view-template"
        },
        {
          "include": "#style-template"
        },
        {
          "include": "source.js"
        }
      ]
    },
    "contract-block": {
      "begin": "(\\bexport)(\\s+)(<)(contract)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.js"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "4": {
          "name": "entity.name.tag.jacare entity.name.tag.jacare.contract entity.name.tag"
        },
        "5": {
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(contract)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.jacare entity.name.tag.jacare.contract entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.contract.jacare",
      "contentName": "meta.embedded.block.contract.jacare source.js",
      "patterns": [
        {
          "include": "#contract-fields"
        },
        {
          "include": "source.js"
        }
      ]
    },
    "contract-fields": {
      "match": "\\b(props|pulses|slots|emits|forwards|links)\\b(?=\\s*:)",
      "name": "keyword.other.contract.jacare support.type.property-name.json"
    },
    "style-blocks": {
      "patterns": [
        {
          "include": "#style-block-scss"
        },
        {
          "include": "#style-block-less"
        },
        {
          "include": "#style-block-css"
        }
      ]
    },
    "style-block-css": {
      "begin": "(\\bexport)(\\s+)(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.js"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "4": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "5": {
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.style.jacare",
      "contentName": "meta.embedded.block.css.jacare source.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "style-block-scss": {
      "begin": "(\\bexport)(\\s+)(<)(style)\\b([^>]*\\blang\\s*=\\s*['\"]scss['\"][^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.js"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "4": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "5": {
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.style.jacare",
      "contentName": "meta.embedded.block.scss.jacare source.css.scss",
      "patterns": [
        {
          "include": "source.css.scss"
        }
      ]
    },
    "style-block-less": {
      "begin": "(\\bexport)(\\s+)(<)(style)\\b([^>]*\\blang\\s*=\\s*['\"]less['\"][^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.js"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "4": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "5": {
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.style.jacare",
      "contentName": "meta.embedded.block.less.jacare source.css.less",
      "patterns": [
        {
          "include": "source.css.less"
        }
      ]
    },
    "view-block": {
      "begin": "(\\bexport(?:\\s+default)?|\\breturn)(\\s+)(<)(view)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.js"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "4": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "5": {
          "patterns": [
            {
              "include": "#tag-attributes"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(view)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.template.jacare meta.embedded.block.html.jacare",
      "contentName": "text.html.jacare",
      "patterns": [
        {
          "include": "#template-body"
        }
      ]
    },
    "view-template": {
      "begin": "(\\bview)(\\s+)(`)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "string.template.jacare punctuation.definition.string.template.begin"
        }
      },
      "end": "`",
      "endCaptures": {
        "0": {
          "name": "string.template.jacare punctuation.definition.string.template.end"
        }
      },
      "name": "string.template.jacare meta.template.jacare",
      "patterns": [
        {
          "include": "#template-body"
        }
      ]
    },
    "style-template": {
      "begin": "(\\bstyle)(\\s+)(`)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.tag.jacare entity.name.tag"
        },
        "2": {
          "name": "source.jacare"
        },
        "3": {
          "name": "string.template.jacare punctuation.definition.string.template.begin"
        }
      },
      "end": "`",
      "endCaptures": {
        "0": {
          "name": "string.template.jacare punctuation.definition.string.template.end"
        }
      },
      "name": "string.template.jacare meta.style.jacare",
      "contentName": "meta.embedded.block.css.jacare source.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        {
          "match": "\\blang\\s*(=)\\s*(['\"])(scss|less|css|sass)(\\2)",
          "captures": {
            "1": {
              "name": "punctuation.separator.key-value.html"
            },
            "2": {
              "name": "string.quoted.double.html"
            },
            "3": {
              "name": "entity.other.attribute-name.html"
            },
            "4": {
              "name": "string.quoted.double.html"
            }
          }
        },
        {
          "match": "\\b([:@A-Za-z_][\\w:.-]*)\\s*(=)\\s*(['\"])([^'\"]*)\\3",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.html"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            },
            "3": {
              "name": "string.quoted.double.html"
            },
            "4": {
              "name": "string.quoted.double.html"
            }
          }
        }
      ]
    },
    "template-body": {
      "patterns": [
        {
          "include": "#directives"
        },
        {
          "include": "#template-expr"
        },
        {
          "include": "#html-tags"
        },
        {
          "include": "#html-attrs"
        },
        {
          "include": "#strings"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "match": "^\\s*(#if|#elif|#else|#end|#case|#when|#for|@if|@elseif|@else|@end|@each)\\b",
          "name": "keyword.control.jacare keyword.control.flow"
        }
      ]
    },
    "template-expr": {
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.jacare punctuation.section.embedded"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.jacare punctuation.section.embedded"
        }
      },
      "name": "meta.embedded.expression.jacare meta.embedded.line.js",
      "contentName": "source.js",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "html-tags": {
      "patterns": [
        {
          "match": "(</?)([A-Z][\\w]*)(\\s|/?>)",
          "captures": {
            "1": {
              "name": "punctuation.definition.tag.begin.html"
            },
            "2": {
              "name": "entity.name.type.tag.jacare support.class.component"
            },
            "3": {
              "name": "punctuation.definition.tag.end.html"
            }
          }
        },
        {
          "match": "(</?)(slot|debug|div|span|p|a|button|input|label|ul|ol|li|nav|main|header|footer|section|article|h[1-6]|form|select|option|textarea|pre|code|table|tr|td|th|thead|tbody|img|br|hr|dl|dt|dd|strong|em|small|figure|figcaption|template|view|style|contract)(\\s|/?>)",
          "captures": {
            "1": {
              "name": "punctuation.definition.tag.begin.html"
            },
            "2": {
              "name": "entity.name.tag.html entity.name.tag"
            },
            "3": {
              "name": "punctuation.definition.tag.end.html"
            }
          }
        },
        {
          "match": "(</?)([a-z][\\w-]*)(\\s|/?>)",
          "captures": {
            "1": {
              "name": "punctuation.definition.tag.begin.html"
            },
            "2": {
              "name": "entity.name.tag.html entity.name.tag"
            },
            "3": {
              "name": "punctuation.definition.tag.end.html"
            }
          }
        }
      ]
    },
    "html-attrs": {
      "patterns": [
        {
          "match": "\\b(bind-[\\w-]+|class-[\\w-]+|on-[\\w-]+|jacare-[\\w-]+|@[\\w-]+|:?[\\w-]+)\\s*(=)",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.html entity.other.attribute-name"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\"",
          "name": "string.quoted.double.html string.quoted.double"
        },
        {
          "match": "'[^'\\\\]*(?:\\\\.[^'\\\\]*)*'",
          "name": "string.quoted.single.html string.quoted.single"
        }
      ]
    }
  }
}
