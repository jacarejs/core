{
  "name": "jacare",
  "displayName": "Jacaré",
  "description": "Syntax highlighting and icons for Jacaré .jcr files",
  "version": "0.0.9",
  "publisher": "heberalmeida",
  "author": {
    "name": "Heber Almeida"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#0b3d2e",
    "theme": "dark"
  },
  "icon": "icons/jacare-256.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/vscode-jacare"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:jacare"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jacare",
        "aliases": [
          "Jacaré",
          "jacare",
          "jcr"
        ],
        "extensions": [
          ".jcr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/jacare-128.png",
          "dark": "./icons/jacare-128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "jacare",
        "scopeName": "source.jacare",
        "path": "./syntaxes/jacare.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.css.jacare": "css",
          "meta.embedded.block.scss.jacare": "scss",
          "meta.embedded.block.less.jacare": "less",
          "meta.embedded.block.html.jacare": "html",
          "meta.embedded.expression.jacare": "javascript",
          "text.html.jacare": "html"
        }
      }
    ],
    "iconThemes": [
      {
        "id": "jacare-icons",
        "label": "Jacaré Icons",
        "path": "./icons/jacare-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.iconTheme": "jacare-icons",
      "editor.tokenColorCustomizations": {
        "[Default Dark Modern]": {
          "textMateRules": [
            {
              "scope": "entity.name.tag.jacare",
              "settings": {
                "foreground": "#569CD6"
              }
            },
            {
              "scope": "keyword.control.jacare",
              "settings": {
                "foreground": "#C586C0",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.type.tag.jacare",
              "settings": {
                "foreground": "#4EC9B0"
              }
            },
            {
              "scope": [
                "punctuation.section.embedded.begin.jacare",
                "punctuation.section.embedded.end.jacare"
              ],
              "settings": {
                "foreground": "#569CD6"
              }
            },
            {
              "scope": "string.template.jacare",
              "settings": {
                "foreground": "#CE9178"
              }
            }
          ]
        },
        "[Default Dark+]": {
          "textMateRules": [
            {
              "scope": "entity.name.tag.jacare",
              "settings": {
                "foreground": "#569CD6"
              }
            },
            {
              "scope": "keyword.control.jacare",
              "settings": {
                "foreground": "#C586C0",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.type.tag.jacare",
              "settings": {
                "foreground": "#4EC9B0"
              }
            },
            {
              "scope": [
                "punctuation.section.embedded.begin.jacare",
                "punctuation.section.embedded.end.jacare"
              ],
              "settings": {
                "foreground": "#569CD6"
              }
            },
            {
              "scope": "string.template.jacare",
              "settings": {
                "foreground": "#CE9178"
              }
            }
          ]
        },
        "[Default Light Modern]": {
          "textMateRules": [
            {
              "scope": "entity.name.tag.jacare",
              "settings": {
                "foreground": "#800000"
              }
            },
            {
              "scope": "keyword.control.jacare",
              "settings": {
                "foreground": "#AF00DB",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.type.tag.jacare",
              "settings": {
                "foreground": "#267F99"
              }
            },
            {
              "scope": [
                "punctuation.section.embedded.begin.jacare",
                "punctuation.section.embedded.end.jacare"
              ],
              "settings": {
                "foreground": "#0000FF"
              }
            },
            {
              "scope": "string.template.jacare",
              "settings": {
                "foreground": "#A31515"
              }
            }
          ]
        },
        "[Default Light+]": {
          "textMateRules": [
            {
              "scope": "entity.name.tag.jacare",
              "settings": {
                "foreground": "#800000"
              }
            },
            {
              "scope": "keyword.control.jacare",
              "settings": {
                "foreground": "#AF00DB",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.type.tag.jacare",
              "settings": {
                "foreground": "#267F99"
              }
            },
            {
              "scope": [
                "punctuation.section.embedded.begin.jacare",
                "punctuation.section.embedded.end.jacare"
              ],
              "settings": {
                "foreground": "#0000FF"
              }
            },
            {
              "scope": "string.template.jacare",
              "settings": {
                "foreground": "#A31515"
              }
            }
          ]
        },
        "textMateRules": [
          {
            "scope": "entity.name.tag.jacare",
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": "keyword.control.jacare",
            "settings": {
              "foreground": "#C586C0",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "entity.name.type.tag.jacare",
            "settings": {
              "foreground": "#4EC9B0"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  }
}
