{
  "name": "jacare",
  "displayName": "Jacaré",
  "description": "Syntax highlighting and icons for Jacaré .jcr files",
  "version": "0.0.4",
  "publisher": "heberalmeida",
  "author": {
    "name": "Heber Almeida"
  },
  "license": "MIT",
  "icon": "icons/jacare-256.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/vscode-jacare"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:jacare"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jacare",
        "aliases": [
          "Jacaré",
          "jacare",
          "jcr"
        ],
        "extensions": [
          ".jcr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/jacare-128.png",
          "dark": "./icons/jacare-128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "jacare",
        "scopeName": "source.jacare",
        "path": "./syntaxes/jacare.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "jacare-icons",
        "label": "Jacaré Icons",
        "path": "./icons/jacare-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.iconTheme": "jacare-icons"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  }
}
