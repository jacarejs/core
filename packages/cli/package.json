{
  "name": "@jacare/cli",
  "version": "0.1.0",
  "description": "Jacaré CLI — create and run Jacaré apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacarejs/core.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
